@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Movie Recommender</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Licenta_Movie_Recommender.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
</head>

<body class="bg-dark text-light">

    <div id="particles-js"></div>
    
    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-danger" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-camera-reels me-1"></i> Movie Recommender
                </a>

                <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item fw-bold">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Acasa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Movies" asp-action="Index">Catalog Filme</a>
                        </li>
                    </ul>

                    @* --- CAUTARE --- *@
                    <form class="d-flex position-relative ms-auto" asp-controller="Movies" asp-action="Index" method="get" id="searchForm">
                        <input class="form-control me-2 bg-dark text-light border-secondary" type="search" placeholder="Cauta filme..." name="searchString" id="searchInput" autocomplete="off">
                        <button class="btn btn-outline-danger" type="submit"><i class="bi bi-search"></i></button>

                        <div id="searchPreviewDropdown" class="dropdown-menu w-100 shadow-lg p-0" style="position: absolute; top: 110%; display: none; background-color: #1f1f1f; border: 1px solid rgba(255,255,255,0.1); z-index: 1050;">
                            <div id="searchResultsList" class="list-group list-group-flush m-0"></div>
                        </div>
                    </form>

                    @* --- USER DROPDOWN --- *@
                    <ul class="navbar-nav ms-3 align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center p-0" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=dc3545&color=fff&rounded=true" alt="Avatar" width="35" height="35" class="rounded-circle border border-secondary shadow-sm">
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-secondary mt-2 bg-dark">
                                    <li><h6 class="dropdown-header text-danger">Salut, @User.Identity.Name!</h6></li>
                                    <li><hr class="dropdown-divider border-secondary"></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item text-warning py-2 fw-bold" asp-controller="Admin" asp-action="Index">
                                                <i class="bi bi-shield-lock me-2"></i> Panou Admin
                                            </a>
                                        </li>
                                    }

                                    <li><a class="dropdown-item text-light py-2" asp-controller="Movies" asp-action="MyProfile"><i class="bi bi-person-badge me-2 text-muted"></i> Profilul Meu</a></li>
                                    <li><hr class="dropdown-divider border-secondary"></li>

                                    @* FIX LOGOUT: Formular POST pentru securitate *@
                                    <li>
                                        <form id="logoutForm" class="d-none" asp-controller="Account" asp-action="Logout" method="post"></form>
                                        <a class="dropdown-item text-danger py-2 fw-bold" href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();">
                                            <i class="bi bi-box-arrow-right me-2"></i> Deconectare
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Login">Intra in cont</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-sm btn-danger fw-bold" asp-controller="Account" asp-action="Register">Cont Nou</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
   

    <footer class="border-top border-secondary footer text-muted mt-5 py-3">
        <div class="container text-center small">
            &copy; 2026 - Scenapse
        </div>
    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null || TempData["SuccessToast"] != null || TempData["Error"] != null)
    {
        var msg = TempData["Success"] ?? TempData["SuccessToast"] ?? TempData["Error"];
        var type = TempData["Error"] != null ? "danger" : "success";
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                showDynamicToast('@msg', '@type');
            });
        </script>
    }

    <!-- Modal confirmare globala -->
    <div class="modal fade" id="confirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-white">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="confirmModalTitle">Confirmare</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="confirmModalBody">
                    Ești sigur?
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulează</button>
                    <button type="button" class="btn btn-danger" id="confirmModalOkBtn">Confirmă</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>