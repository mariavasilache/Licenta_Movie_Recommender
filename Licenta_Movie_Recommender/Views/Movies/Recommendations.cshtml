@model List<Licenta_Movie_Recommender.Models.RecommendedMovie>

@{
    ViewData["Title"] = "Recomandări pentru tine";
    var userActivities = ViewBag.UserActivities as List<Licenta_Movie_Recommender.Models.UserMovieActivity>
                         ?? new List<Licenta_Movie_Recommender.Models.UserMovieActivity>();
}

<div class="container mt-4 mb-5">
    <partial name="_PageHeader" model='"Recomandări Personalizate"' />

    @if (Model == null || !Model.Any())
    {
        <div class="alert bg-transparent border border-secondary shadow-sm py-5 text-center rounded-3">
            <i class="bi bi-info-circle display-4 d-block mb-3 text-secondary opacity-50"></i>
            <h4 class="fw-bold text-light">Avem nevoie de mai multe date!</h4>
            <p class="mb-0 text-muted">Algoritmul nostru inteligent are nevoie să evaluezi (cu note de la 1 la 5) <strong>cel puțin 5 filme</strong> pentru a-ți putea crea un profil precis de preferințe.</p>
            <a asp-controller="Movies" asp-action="Index" class="btn btn-danger mt-4 px-4 shadow-sm fw-bold"><i class="bi bi-film me-2"></i> Explorează Catalogul</a>
        </div>
    }
    else
    {
        <div class="alert bg-dark border border-success shadow-sm mb-4 rounded-3 d-flex align-items-center p-3">
            <i class="bi bi-check-circle-fill text-success fs-3 me-3"></i>
            <div class="text-light">
                <strong class="text-success"></strong> Aceste recomandări sunt calculate pe baza filmelor pe care le-ai apreciat și a genurilor tale preferate.
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                var activity = userActivities.FirstOrDefault(a => a.MovieId == item.Movie.Id);
                var inWatchlist = activity != null && activity.Status == 1 && activity.Rating == 0;
                var isWatched = activity != null && (activity.Status == 2 || activity.Rating > 0);

                <div class="col-lg-2 col-md-3 col-sm-4 col-6 mb-4">
                    <partial name="_MovieCard" model="item.Movie"
                             view-data='new ViewDataDictionary(ViewData) { { "InWatchlist", inWatchlist }, { "IsWatched", isWatched }, { "Layout", "grid_nocontainer" }, { "ShowIgnore", true } }' />
                    @if (!string.IsNullOrEmpty(item.Explanation))
                    {
                        var parts = item.Explanation.Split('|');
                        var icon = parts[0];
                        var text = parts[1];
                        var iconClass = icon == "heart" ? "bi-heart-fill" : icon == "clock" ? "bi-clock-fill" : "bi-fire";
                        <span class="explanation-badge d-block mt-1">
                            <i class="bi @iconClass me-1"></i><strong>@text</strong>
                        </span>
                    }
                </div>
            }
        </div>
    }
</div>