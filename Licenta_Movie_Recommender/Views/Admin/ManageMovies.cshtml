@model IEnumerable<Licenta_Movie_Recommender.Models.Movie>
@{
    ViewData["Title"] = "Gestionare Filme";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 text-gray-800">Gestionare Bază de Date Filme</h1>
        <a href="/Admin/Import" class="btn btn-success shadow-sm">
            <i class="bi bi-cloud-download me-1"></i> Importă filme noi
        </a>
    </div>

    @* --- BARA DE CAUTARE --- *@
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="searchString" class="form-control"
                           placeholder="Caută după titlu..." value="@ViewBag.SearchString">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Caută</button>
                </div>
            </form>
        </div>
    </div>

    @* --- TABEL FILME --- *@
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;">ID</th>
                            <th style="width: 80px;">Poster</th>
                            <th>Titlu</th>
                            <th>Genuri</th>
                            <th class="text-center">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="movie-row-@item.Id">
                                <td>@item.Id</td>
                                <td>
                                    <img src="@item.PosterUrl" style="width: 50px; border-radius: 4px;"
                                         onerror="this.src='https://placehold.co/50x75?text=N/A'" />
                                </td>
                                <td class="fw-bold">@item.Title</td>
                                <td>
                                    @foreach (var gen in (item.Genres ?? "").Split('|'))
                                    {
                                        <span class="badge bg-light text-dark border me-1">@gen</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="/Movies/Details/@item.Id" class="btn btn-sm btn-outline-info" title="Vezi pagina">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteMovie(@item.Id, '@item.Title')" title="Șterge film">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* --- PAGINATIE --- *@
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("ManageMovies", new { page = i, searchString = ViewBag.SearchString })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function deleteMovie(id, title) {
            if (!confirm(`Sigur vrei să ștergi definitiv filmul "${title}"?`)) return;

            try {
                const response = await fetch(`/Admin/DeleteMovie/${id}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    const row = document.getElementById(`movie-row-${id}`);
                    row.style.transition = 'all 0.5s ease';
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 500);
                } else {
                    alert("Eroare la ștergere. Posibil să existe restricții în baza de date.");
                }
            } catch (err) {
                console.error(err);
            }
        }
    </script>
}