@{
    ViewData["Title"] = "Gestionare Filme";
}

<div class="container-fluid mt-4 mb-5">
    @* --- HEADER CU BUTON DE INAPOI --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a href="/Admin" class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;" title="Înapoi la Dashboard">
                <i class="bi bi-arrow-left fs-5"></i>
            </a>
            <h1 class="h3 text-white fw-bold mb-0">Gestionare Filme</h1>
        </div>

        <a href="/Admin/Import" class="btn btn-success shadow-sm">
            <i class="bi bi-cloud-download me-1"></i> Importă filme noi
        </a>
    </div>

    @* --- BARA DE CAUTARE --- *@
    <div class="card bg-dark border-secondary shadow mb-4">
        <div class="card-body">
            <form id="adminSearchForm" class="row g-3">
                <div class="col-md-10">
                    <input type="text" id="adminSearchInput" class="form-control bg-dark text-white border-secondary" placeholder="Caută după titlu...">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Caută
                    </button>
                </div>
            </form>
        </div>
    </div>

   

    @* --- TABURI FILTRARE --- *@
    <ul class="nav nav-pills nav-fill mb-4 bg-dark border border-secondary rounded shadow-sm p-1" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-light admin-tab-btn" data-filter="all" type="button">
                <i class="bi bi-collection-play-fill"></i> Toate
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-light admin-tab-btn" data-filter="active" type="button">
                <i class="bi bi-check-circle-fill text-success"></i> Active
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-light admin-tab-btn" data-filter="deleted" type="button">
                <i class="bi bi-trash-fill text-danger"></i> Șterse
            </button>
        </li>
    </ul>

    <style>
       
        #adminTabs .nav-link.active {
            background-color: #dc3545 !important;
            color: white !important;
        }
    </style>

    @* --- GRID FILME --- *@
    <div id="adminMovieGrid" class="row g-2"></div>

    @* --- LOADER --- *@
    <div id="adminLoader" class="text-center my-5" style="display:none;">
        <div class="spinner-border text-danger shadow-sm" role="status"></div>
    </div>
</div>

@section Scripts {
    <script>
        let page = 1;
        let isLoading = false;
        let hasMore = true;
        let searchString = '';
        let currentFilter = 'all';

        async function loadAdminMovies() {
            if (isLoading || !hasMore) return;
            isLoading = true;

            const grid = document.getElementById('adminMovieGrid');
            const loader = document.getElementById('adminLoader');

            loader.style.display = 'block';

            try {
                const response = await fetch(`/Admin/GetManageMoviesData?page=${page}&searchString=${encodeURIComponent(searchString)}&filter=${currentFilter}`);
                const movies = await response.json();

                if (page === 1) grid.innerHTML = '';

                if (movies.length === 0) {
                    hasMore = false;
                    if (page === 1) grid.innerHTML = `
                            <div class="col-12 text-center text-muted py-5 border border-secondary rounded-3 bg-transparent">
                                <i class="bi bi-camera-reels display-6 d-block mb-3 opacity-50"></i>
                                Nu am găsit niciun film.
                            </div>`;
                } else {
                    let html = '';
                    movies.forEach(movie => {
                        html += createMovieCardHtml(movie, { isAdmin: true, layout: 'compact' });
                    });

                    
                    grid.insertAdjacentHTML('beforeend', html);
                    page++;
                }
            } catch (error) {
                console.error("Eroare la încărcare:", error);
            } finally {
                isLoading = false;
                loader.style.display = 'none';
            }
        }

        // --- click tab uri ---
        document.querySelectorAll('.admin-tab-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {

                document.querySelectorAll('.admin-tab-btn').forEach(b => b.classList.remove('active'));

                const clickedBtn = e.currentTarget;
                clickedBtn.classList.add('active');

                currentFilter = clickedBtn.getAttribute('data-filter');

                page = 1;
                hasMore = true;
                loadAdminMovies();
            });
        });

        // Cautare
        let debounceTimerAdmin;
        document.getElementById('adminSearchInput').addEventListener('input', (e) => {
            clearTimeout(debounceTimerAdmin); 

            debounceTimerAdmin = setTimeout(() => {
                searchString = e.target.value.trim();
                page = 1;
                hasMore = true;
                loadAdminMovies(); 
            }, 400);
        });

        document.getElementById('adminSearchForm').addEventListener('submit', (e) => e.preventDefault());


        // scroll Infinit
        window.addEventListener('scroll', () => {
            if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 500) {
                loadAdminMovies();
            }
        });

        
        document.addEventListener('DOMContentLoaded', loadAdminMovies);
    </script>
}