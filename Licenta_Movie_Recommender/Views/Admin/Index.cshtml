@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["IsAdminArea"] = true;
    ViewData["Layout"] = "compact";
}

<div class="container-fluid mt-4 mb-5">
    <h1 class="h3 mb-4 text-white fw-bold">Panou de Control</h1>

    @* --- CARDURI STATISTICI --- *@
    <div class="row">
        @* Total Filme *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card bg-dark text-white shadow h-100 py-2 border-0 border-left-primary">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Filme</div>
                            <div class="h5 mb-0 font-weight-bold">@Model.TotalMovies</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-film fs-2 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Total utilizatori *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card bg-dark text-white shadow h-100 py-2 border-0 border-left-success">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Utilizatori</div>
                            <div class="h5 mb-0 font-weight-bold">@Model.TotalUsers</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-people fs-2 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Recenzii Totale *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card bg-dark text-white shadow h-100 py-2 border-0 border-left-warning">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Recenzii Date</div>
                            <div class="h5 mb-0 font-weight-bold">@Model.TotalRatings</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-star-fill fs-2 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- COLOANE PREVIEW FILME SI USERI --- *@
    <div class="row g-4 mt-2">

        <div class="col-12 col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm h-100">
                <div class="card-header border-secondary d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 text-white"><i class="bi bi-film me-2 text-primary"></i> Ultimele Filme</h5>
                    <a href="/Admin/ManageMovies" class="btn btn-sm btn-outline-primary">Vezi Toate <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div class="card-body p-3">
                    <div class="row m-0">
                        @if (Model.RecentMovies != null && Model.RecentMovies.Any())
                        {
                            @foreach (var movie in Model.RecentMovies.Take(5))
                            {
                                @await Html.PartialAsync("_MovieCard", movie)
                            }
                        }
                        else
                        {
                            <div class="col-12 p-4 text-center text-muted border border-secondary rounded">
                                <i class="bi bi-camera-reels display-6 d-block mb-2 opacity-50"></i>
                                Niciun film adăugat recent.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card bg-dark border-secondary shadow-sm h-100">
                <div class="card-header border-secondary d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 text-white"><i class="bi bi-people me-2 text-success"></i> Utilizatori Noi</h5>
                    <a href="/Admin/ManageUsers" class="btn btn-sm btn-outline-success">Vezi Toți <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (Model.RecentUsers != null && Model.RecentUsers.Any())
                        {
                            @foreach (var user in Model.RecentUsers.Take(5))
                            {
                                <div class="list-group-item bg-transparent border-secondary text-white d-flex align-items-center p-3 hover-bg-light">
                                    <div class="bg-secondary bg-opacity-25 rounded-circle d-flex justify-content-center align-items-center me-3 border border-secondary shadow-sm" style="width: 50px; height: 50px;">
                                        <i class="bi bi-person-fill text-light fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <h6 class="mb-1 text-truncate fw-bold">@user.UserName</h6>
                                        <small class="text-muted text-truncate d-block"><i class="bi bi-envelope me-1"></i> @user.Email</small>
                                    </div>
                                    <span class="badge bg-success bg-opacity-75">Activ</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="bi bi-person-x display-6 d-block mb-2 opacity-50"></i>
                                Nu există utilizatori recenți.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .border-left-primary {
        border-left: 4px solid #0d6efd !important;
    }

    .border-left-success {
        border-left: 4px solid #198754 !important;
    }

    .border-left-warning {
        border-left: 4px solid #ffc107 !important;
    }

    .card.bg-dark {
        background-color: #1f1f1f !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
    }
</style>