@model IEnumerable<Licenta_Movie_Recommender.Models.Movie>
@{
    ViewData["Title"] = "Catalog Filme";
    string sort = ViewBag.CurrentSort;
    string genre = ViewBag.CurrentGenre;
}

<div class="container mt-4 mb-5">
    <partial name="_PageHeader" model='(string)ViewData["Title"]' />

    @* --- FILTRARE SI SORTARE --- *@
    <div class="filter-section bg-dark p-3 rounded-3 shadow-sm mb-4 border border-secondary sticky-top" style="--bs-bg-opacity: .4; top: 70px; z-index: 99;">
        @* GENURI *@
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <span class="text-muted small fw-bold text-uppercase me-2">Gen:</span>
            <button class="btn btn-sm btn-danger rounded-pill px-3 genre-btn active" data-genre="">Toate</button>
            @foreach (var g in ViewBag.Genres as List<string>)
            {
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 genre-btn" data-genre="@g">@g</button>
            }
        </div>

        @* SORTARE *@
        <div class="d-flex flex-wrap gap-2 align-items-center pt-2 border-top border-secondary">
            <span class="text-muted small fw-bold text-uppercase me-2">Sortare:</span>
            <button class="btn btn-sm btn-outline-light rounded-pill px-3 fw-bold sort-btn" data-sort="title_asc">A - Z</button>
            <button class="btn btn-sm btn-outline-light rounded-pill px-3 fw-bold sort-btn" data-sort="title_desc">Z - A</button>
            <button class="btn btn-sm btn-sort-active rounded-pill px-3 fw-bold sort-btn active" data-sort="">Cele mai noi</button>
            <button class="btn btn-sm btn-outline-light rounded-pill px-3 fw-bold sort-btn" data-sort="oldest">Cele mai vechi</button>
        </div>
    </div>

    @* --- GRILA FILME (INFINITE SCROLL) --- *@
    <div id="catalogGrid" class="row"></div>

    @* --- LOADER PENTRU SCROLL --- *@
    <div id="catalogLoader" class="text-center my-5" style="display:none;">
        <div class="spinner-border text-danger shadow-sm" role="status"></div>
        <div class="small text-muted mt-2 fw-bold">Se încarcă catalogul...</div>
    </div>
</div>

@section Scripts {
    <script>
        let page = 1;
        let isLoading = false;
        let hasMore = true;

        const urlParams = new URLSearchParams(window.location.search);
        const searchString = urlParams.get('searchString') || "";
        let sortOrder = urlParams.get('sortOrder') || "";
        let genreFilter = urlParams.get('genreFilter') || "";

                async function loadMovies() {
            if (isLoading || !hasMore) return;
            isLoading = true;

            const grid = document.getElementById('catalogGrid');
            const loader = document.getElementById('catalogLoader');

            if (page === 1) grid.innerHTML = getSkeletonsHtml(12);
            if (page > 1 && loader) loader.style.display = 'block';

            const currentSearch = window._catalogSearch !== undefined
                ? window._catalogSearch
                : searchString;

            try {
                const response = await fetch(`/Movies/GetCatalogData?page=${page}&sortOrder=${sortOrder}&genreFilter=${genreFilter}&searchString=${currentSearch}`);
                const movies = await response.json();

                if (page === 1) grid.innerHTML = '';

                if (movies.length === 0) {
                    hasMore = false;
                    if (page === 1) {
                        grid.innerHTML = '<div class="col-12 text-center text-muted py-5">Nu am găsit niciun film pentru criteriile selectate.</div>';
                    }
                } else {
                    let html = '';
                    movies.forEach(movie => {
                        html += createMovieCardHtml(movie);
                    });
                    grid.insertAdjacentHTML('beforeend', html);
                    page++;
                }
            } catch (error) {
                console.error("Eroare la încărcarea catalogului:", error);
            } finally {
                isLoading = false;
                if (loader) loader.style.display = 'none';
            }
        }

        // eveniment scroll
        window.addEventListener('scroll', () => {
            if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 600) {
                loadMovies();
            }
        });

        // setActivePill - clasele separate ca classList nu accepta spatii
        function setActivePill(group, activeEl, activeClasses, inactiveClass) {
            group.forEach(btn => {
                activeClasses.forEach(c => btn.classList.remove(c));
                btn.classList.add(inactiveClass);
                btn.classList.remove('active');
            });
            activeClasses.forEach(c => activeEl.classList.add(c));
            activeEl.classList.remove(inactiveClass);
            activeEl.classList.add('active');
        }

        // expunem functia pt site.js (vezi toate rezultate din search)
        window._triggerCatalogSearch = function(query) {
            page = 1;
            hasMore = true;
            window._catalogSearch = query;
            loadMovies();
        };

        document.addEventListener('DOMContentLoaded', () => {
            const genreBtns = document.querySelectorAll('.genre-btn');
            genreBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    genreFilter = btn.dataset.genre;
                    setActivePill(genreBtns, btn, ['btn-danger'], 'btn-outline-secondary');
                    page = 1; hasMore = true;
                    document.getElementById('catalogGrid').innerHTML = '';
                    loadMovies();
                });
            });

            const sortBtns = document.querySelectorAll('.sort-btn');
            sortBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    sortOrder = btn.dataset.sort;
                    setActivePill(sortBtns, btn, ['btn-sort-active'], 'btn-outline-light');
                    page = 1; hasMore = true;
                    document.getElementById('catalogGrid').innerHTML = '';
                    loadMovies();
                });
            });

            loadMovies();

            // search live in catalog
            const catalogSearch = document.getElementById('searchInput');
            if (catalogSearch) {
                catalogSearch.value = searchString;
                let catalogDebounce;
                catalogSearch.addEventListener('input', function() {
                    clearTimeout(catalogDebounce);
                    catalogDebounce = setTimeout(() => {
                        window._triggerCatalogSearch(this.value.trim());
                    }, 400);
                });
            }
        });
    </script>
}